// AuMatch Concierge — data model
// Postgres in every environment (local / Vercel Postgres / Neon / Heroku Postgres).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MEMBER // a family or provider with a portal account
  CONCIERGE // internal staff
  ADMIN // owner / full access
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  PLACED
  CLOSED
  ARCHIVED
}

enum ServiceLine {
  CHILDCARE // Premium Child & Newborn Care (月嫂/育儿嫂)
  ESTATE // Estate Management & Concierge (私人管家)
  CLEANING // Specialized Cleaning (专项保洁)
  OTHER
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

// ───────── Auth.js (NextAuth) core models ─────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String? // null for OAuth-only accounts
  // 'family' or 'provider' — captured at registration for portal personalization.
  portalRole    String?   @default("family")
  role          Role      @default(MEMBER)

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────── AuMatch domain models ─────────

// P0: Employer (family) intake — "Find a Caregiver".
model EmployerLead {
  id        String        @id @default(cuid())
  fullName  String
  phone     String
  email     String
  location  String // Cary, Raleigh, Durham, Chapel Hill, Apex, Morrisville, Other
  services  ServiceLine[] // multi-select
  frequency String? // live-in / full-time / part-time / one-time
  budget    String? // 25-35 / 35-50 / 50+ / salaried
  startDate DateTime?
  notes     String?       @db.Text

  status         LeadStatus @default(NEW)
  conciergeNotes String?    @db.Text
  locale         String     @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// P0: Care professional application — "Join as Provider".
model ProviderApplication {
  id            String     @id @default(cuid())
  fullName      String
  phone         String
  email         String
  city          String
  availability  String? // live-in / full-time / part-time / flexible
  expectedRate  String?
  // Uploaded resume / certificate metadata (file stored in blob storage).
  documentUrl   String?
  documentName  String?
  consentBgCheck Boolean   @default(false)

  status         LeadStatus @default(NEW)
  conciergeNotes String?    @db.Text
  locale         String     @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// Consultation booking. When Calendly is connected, its webhook upserts here;
// the in-app booking form also writes here as a fallback.
model ConsultBooking {
  id        String  @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  topic     String? // childcare / estate / cleaning / unsure
  startTime DateTime?
  endTime   DateTime?

  // Calendly linkage (nullable for in-app bookings).
  calendlyEventUri  String?       @unique
  calendlyInviteeId String?
  rawPayload        Json?

  status    BookingStatus @default(SCHEDULED)
  locale    String        @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([startTime])
}
