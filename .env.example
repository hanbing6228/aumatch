# ───────────────────────────────────────────────────────────────
# AuMatch Concierge — environment variables
# Copy to `.env` for local dev. In production set these in Vercel.
# NEVER commit a filled-in .env file.
# ───────────────────────────────────────────────────────────────

# --- Database (Postgres) ---
# Pooled connection used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aumatch?schema=public"
# Direct (non-pooled) connection used by Prisma migrations. For Vercel
# Postgres/Neon this is the *_URL_NON_POOLING value; for plain Postgres it can
# equal DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/aumatch?schema=public"

# --- Auth.js / NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Canonical site URL. Locally http://localhost:3000 ; in prod your domain.
AUTH_URL="http://localhost:3000"
# Trust the host header (required on Vercel / proxies).
AUTH_TRUST_HOST="true"

# --- Google OAuth ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Calendly ---
# Public scheduling URL embedded for members, e.g.
# https://calendly.com/aumatch/intro-call
NEXT_PUBLIC_CALENDLY_URL=""
# Signing key from the Calendly webhook subscription (verifies webhook payloads).
CALENDLY_WEBHOOK_SIGNING_KEY=""

# --- Admin bootstrap ---
# Comma-separated emails auto-granted ADMIN on first sign-in / seed.
ADMIN_EMAILS="hanbing6228@gmail.com"
